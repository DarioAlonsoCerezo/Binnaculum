{
  "$schema": "https://opencode.ai/config.json",
  "skills": {
    "paths": [
      "./skills"
    ]
  },
  "permission": {
    "skill": {
      "*": "allow"
    }
  },
  "mcp": {
    "cocoindex": {
      "type": "local",
      "command": [
        "pwsh",
        "-NoLogo",
        "-NoProfile",
        "-Command",
        "Set-Location $env:BINNACULUM_COCO_INDEX; ccc mcp"
      ],
      "enabled": true,
      "timeout": 15000
    }
  }
}